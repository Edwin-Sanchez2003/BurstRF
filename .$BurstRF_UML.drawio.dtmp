        <mxCell id="spiaGc8N6B3giQx-SNpL-6" parent="1" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;Backend (C++)&lt;/h1&gt;&lt;p&gt;The compute-intensive parts of the program - manages a relationship with the SigMF Dataset file, computes Spectrograms, and produces QImages for the main view to see.&lt;/p&gt;" vertex="1">
          <mxGeometry height="120" width="350" x="290" as="geometry" />
        </mxCell>
        <mxCell id="spiaGc8N6B3giQx-SNpL-7" parent="1" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;Frontend (QML)&lt;/h1&gt;&lt;p&gt;The visual display for the user - handles user interactions and communicates with the backend to notify it of user input when needed.&lt;/p&gt;" vertex="1">
          <mxGeometry height="120" width="400" x="920" as="geometry" />
        </mxCell>
