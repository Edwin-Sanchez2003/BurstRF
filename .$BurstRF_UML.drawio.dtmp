        </mxCell>
        <mxCell id="spiaGc8N6B3giQx-SNpL-9" parent="1" style="rounded=0;whiteSpace=wrap;html=1;" value="Select SigMF Metadata File" vertex="1">
          <mxGeometry height="20" width="150" x="900" y="100" as="geometry" />
        </mxCell>
        <mxCell id="spiaGc8N6B3giQx-SNpL-10" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;verticalAlign=top;" value="Spectrogram" vertex="1">
          <mxGeometry height="310" width="290" x="1010" y="140" as="geometry" />
        </mxCell>
        <mxCell id="spiaGc8N6B3giQx-SNpL-11" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" value="" vertex="1">
