        <mxCell id="spiaGc8N6B3giQx-SNpL-49" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=top;rounded=0;" value="ChunkSpectrogramProvider knows of SigMFBackend, and passes data to ChunkSpectrogramResponse" vertex="1">
